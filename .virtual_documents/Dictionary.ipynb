


# Dictionary


'''
Dictionary is a mutable data type in Python.
A python dictionary is a collection of key and value pairs separated by a colon (:) & enclosed
in curly braces {}.
Keys must be unique in a dictionary, duplicate values are allowed.
'''


mydict=dict()
mydict


mydict1={}
mydict


mydict1={1:'one',2:'two',3:'three'}
mydict1


mydict=dict({1:'one',2:'two',3:'three'})
mydict


mydict2={'A':'one','B':'two','C':'three'}
mydict2


mydict3={'A':'one',2:'two','three':3}
mydict3


mydict1


mydict1.keys()


mydict1.values()


mydict1.items()


mydict4={1:'one',2:'two','A':['a','b','c'],'B':(1,'two','three')}
mydict4


mydict5={1:'one',2:'two','A':{'a':'rat','b':'bat','c':'mat'},'B':('one','two')}
mydict5


# Create a dictionary from a sequence of keys
keys={'a','b','c','d'}
mydict6=dict.fromkeys(keys)
mydict6


keys={'a','b','c','d'}
value=10
mydict7=dict.fromkeys(keys,value)
mydict7


keys={'a','b','c','d'}
value=[10,20,30]
mydict8=dict.fromkeys(keys,value)
mydict8


value.append(40)
mydict8


# Accessing Items


mydict={1:'one',2:'two',3:'three'}
mydict


mydict[1]


mydict.get(1)


mydict1={'Name':'Andrew','ID':1234,'Job':'Data Engineer'}
mydict1['Name']


mydict1.get('Job')


# Add, Remove & Change Items


mydict1 = {'Name':'Asif' , 'ID': 12345 , 'DOB': 1991 , 'Address' : 'Hilsinki'}
mydict1


mydict1['DOB']=1992
mydict1['Address']='Delhi'
mydict1


dict1={'DOB':1995}
mydict1.update(dict1)
mydict1


mydict1['Job']='Analyst'
mydict1


mydict1.pop('Job')
mydict1


mydict1.popitem()
mydict1


del mydict1['ID']
mydict1


mydict1.clear()
mydict1


del mydict1
mydict1


# Copy Dictionary


mydict = {'Name':'Asif' , 'ID': 12345 , 'DOB': 1991 , 'Address' : 'Hilsinki'}
mydict


mydict2=mydict
mydict2


id(mydict)


id(mydict2)


mydict3=mydict.copy()
mydict3


id(mydict3)


mydict['Address']='Mumbai'
mydict


mydict2 # mydict2 will be also impacted as it is pointing to the same dictionary


mydict3 # Copy of list won't be impacted due to the changes made in the original


# Loop through a Dictionary


mydict1 = {'Name':'Asif' , 'ID': 12345 , 'DOB': 1991 , 'Address' : 'Hilsinki' ,'Job':'Analyst'}
mydict1


for i in mydict1:
  print(i, ':-', mydict1[i])


for i in mydict1:
  print(mydict1[i])


# Dictionary Membership


mydict1 = {'Name':'Asif' , 'ID': 12345 , 'DOB': 1991 , 'Job': 'Analyst'}
mydict1


'Name' in mydict1


'Asif' in mydict1 # Membership test can be only done for keys.


'Job' in mydict1


'Address' in mydict1





mydict1 = {'Name':'Asif' , 'ID': 12345 , 'DOB': 1991 , 'Job': 'Analyst'}
mydict1


all(mydict1)


any(mydict1)



